Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Define", " ", "the", " ", "dispersion", " ", "relation"}], "*)"}],
   "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]k", "[", 
      RowBox[{"k_", ",", "m_"}], "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"k", "^", "2"}], "+", 
       RowBox[{"m", "^", "2"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "the", " ", "integrand", " ", "as", " ", "a", " ", 
     "function", " ", "of", " ", "\[CurlyEpsilon]"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"integrand", "[", 
      RowBox[{
      "Ef_", ",", "Ei_", ",", "q0_", ",", "k_", ",", "m_", ",", 
       "\[CurlyEpsilon]_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"k", "^", "2"}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", " ", "Pi"}], ")"}], "^", "3"}]}], ")"}], "*", 
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[Omega]k", "[", 
           RowBox[{"k", ",", "m"}], "]"}], "-", 
          RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}]}], ")"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"q0", "^", "2"}], "-", 
             RowBox[{"2", " ", "q0", " ", 
              RowBox[{"\[Omega]k", "[", 
               RowBox[{"k", ",", "m"}], "]"}]}], "+", 
             RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"Ei", "-", "Ef"}], ")"}], "^", "2"}], "-", 
             RowBox[{"2", " ", 
              RowBox[{"(", 
               RowBox[{"Ei", "-", "Ef"}], ")"}], " ", 
              RowBox[{"\[Omega]k", "[", 
               RowBox[{"k", ",", "m"}], "]"}]}], "+", 
             RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Ef", "^", "2"}], "+", 
             RowBox[{"2", " ", "Ef", " ", 
              RowBox[{"\[Omega]k", "[", 
               RowBox[{"k", ",", "m"}], "]"}]}], "+", 
             RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}]}], ")"}]}], "+", 
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"q0", "^", "2"}], "+", 
             RowBox[{"2", " ", "q0", " ", 
              RowBox[{"\[Omega]k", "[", 
               RowBox[{"k", ",", "m"}], "]"}]}], "+", 
             RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"Ei", "+", "q0", "-", "Ef"}], ")"}], "^", "2"}], "-", 
             RowBox[{"2", " ", 
              RowBox[{"(", 
               RowBox[{"Ei", "+", "q0", "-", "Ef"}], ")"}], " ", 
              RowBox[{"\[Omega]k", "[", 
               RowBox[{"k", ",", "m"}], "]"}]}], "+", 
             RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"q0", "+", "Ef"}], ")"}], "^", "2"}], "+", 
             RowBox[{"2", " ", 
              RowBox[{"(", 
               RowBox[{"q0", "+", "Ef"}], ")"}], " ", 
              RowBox[{"\[Omega]k", "[", 
               RowBox[{"k", ",", "m"}], "]"}]}], "+", 
             RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}]}], ")"}]}], "+", 
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"Ef", "-", "Ei"}], ")"}], "^", "2"}], "-", 
             RowBox[{"2", " ", 
              RowBox[{"(", 
               RowBox[{"Ef", "-", "Ei"}], ")"}], " ", 
              RowBox[{"\[Omega]k", "[", 
               RowBox[{"k", ",", "m"}], "]"}]}], "+", 
             RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"q0", "+", "Ef", "-", "Ei"}], ")"}], "^", "2"}], "-", 
             RowBox[{"2", " ", 
              RowBox[{"(", 
               RowBox[{"q0", "+", "Ef", "-", "Ei"}], ")"}], " ", 
              RowBox[{"\[Omega]k", "[", 
               RowBox[{"k", ",", "m"}], "]"}]}], "+", 
             RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Ei", "^", "2"}], "+", 
             RowBox[{"2", " ", "Ei", " ", 
              RowBox[{"\[Omega]k", "[", 
               RowBox[{"k", ",", "m"}], "]"}]}], "+", 
             RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}]}], ")"}]}], "+", 
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Ef", "^", "2"}], "-", 
             RowBox[{"2", " ", "Ef", " ", 
              RowBox[{"\[Omega]k", "[", 
               RowBox[{"k", ",", "m"}], "]"}]}], "+", 
             RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"q0", "+", "Ef"}], ")"}], "^", "2"}], "-", 
             RowBox[{"2", " ", 
              RowBox[{"(", 
               RowBox[{"q0", "+", "Ef"}], ")"}], " ", 
              RowBox[{"\[Omega]k", "[", 
               RowBox[{"k", ",", "m"}], "]"}]}], "+", 
             RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Ei", "^", "2"}], "-", 
             RowBox[{"2", " ", "Ei", " ", 
              RowBox[{"\[Omega]k", "[", 
               RowBox[{"k", ",", "m"}], "]"}]}], "+", 
             RowBox[{"I", " ", "\[CurlyEpsilon]"}]}], ")"}]}], ")"}]}]}], 
       ")"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "the", " ", "integral", " ", "as", " ", "a", " ", 
     "function", " ", "of", " ", "\[CurlyEpsilon]"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Int", "[", 
      RowBox[{
      "Ef_", ",", "Ei_", ",", "q0_", ",", "m_", ",", "\[CurlyEpsilon]_"}], 
      "]"}], ":=", 
     RowBox[{"Quiet", "[", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{"integrand", "[", 
         RowBox[{
         "Ef", ",", "Ei", ",", "q0", ",", "k", ",", "m", ",", 
          "\[CurlyEpsilon]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", "\[Infinity]"}], "}"}]}], "]"}], "]"}]}],
     ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Fix", " ", "m"}], "=", "1"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"m", "=", "1"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.957004774750469*^9, 3.9570047933301373`*^9}, {
  3.9570049214313545`*^9, 3.957004924473667*^9}},
