Notebook[{

Cell[CellGroupData[{
Cell["Integral 1 for N3AS ", "Title",
 CellChangeTimes->{{3.9532287822828617`*^9, 3.953228801140913*^9}, {
  3.9532288801034393`*^9, 
  3.953228893194319*^9}},ExpressionUUID->"c71a2b82-092a-f247-b494-\
c716b7244434"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x_", ",", " ", "A_", ",", " ", "\[Epsilon]_"}], "]"}], " ", ":=",
     " ", 
    FractionBox[
     SuperscriptBox["x", "2"], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["x", "2"], "+", "1"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"A", "-", 
        RowBox[{"2", 
         RowBox[{"\[Sqrt]", 
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["x", "2"], "+", "1"}], ")"}]}]}], "+", 
        RowBox[{"\[ImaginaryI]", " ", "\[Epsilon]"}]}], ")"}]}]]}], ";"}], 
  " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Int", "[", 
    RowBox[{"A_", ",", "\[CapitalLambda]_", ",", " ", "\[Epsilon]_"}], "]"}], 
   " ", ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "A", ",", " ", "\[Epsilon]"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0", ",", " ", "\[CapitalLambda]"}], "}"}]}], 
    "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"plot1", " ", "=", " ", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Re", "[", 
     RowBox[{"Int", "[", 
      RowBox[{"A", ",", "20", ",", "1"}], "]"}], "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"A", ",", 
      RowBox[{"-", "60"}], ",", "100"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "4"}], ",", "5"}], "}"}]}], ",", 
    RowBox[{
    "PlotLabel", "->", " ", 
     "\"\<E/m vs Integral value (\[CapitalLambda]/m = 20, \[Epsilon]/m = 1)\>\
\""}], ",", "\[IndentingNewLine]", 
    RowBox[{"AxesLabel", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
      "\"\<Energy per unit mass(E/m)\>\"", ",", " ", 
       "\"\<Value of integral\>\""}], "}"}]}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"plot2", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Re", "[", 
     RowBox[{"Int", "[", 
      RowBox[{"A", ",", "20", ",", ".1"}], "]"}], "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"A", ",", 
      RowBox[{"-", "60"}], ",", "100"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "4"}], ",", "5"}], "}"}]}], ",", 
    RowBox[{
    "PlotLabel", "->", " ", 
     "\"\<E/m vs Integral value (\[CapitalLambda]/m = 20, \[Epsilon]/m = 0.1)\
\>\""}], ",", "\[IndentingNewLine]", 
    RowBox[{"AxesLabel", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
      "\"\<Energy per unit mass(E/m)\>\"", ",", " ", 
       "\"\<Value of integral\>\""}], "}"}]}], ",", 
    RowBox[{"PlotStyle", "->", "Orange"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"plot3", " ", "=", " ", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Re", "[", 
     RowBox[{"Int", "[", 
      RowBox[{"A", ",", "20", ",", ".01"}], "]"}], "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"A", ",", 
      RowBox[{"-", "60"}], ",", "100"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "4"}], ",", "5"}], "}"}]}], ",", 
    RowBox[{
    "PlotLabel", "->", " ", 
     "\"\<E/m vs Integral value (\[CapitalLambda]/m = 20, \[Epsilon]/m = \
0.01)\>\""}], ",", "\[IndentingNewLine]", 
    RowBox[{"AxesLabel", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
      "\"\<Energy per unit mass(E/m)\>\"", ",", " ", 
       "\"\<Value of integral\>\""}], "}"}]}], ",", 
